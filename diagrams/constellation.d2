direction: right

# Tables
Fact_Collision: {
  shape: sql_table
  Collision_ID: string {constraint: primary_key}
  DateKey: int {constraint: foreign_key}
  TimeKey: int {constraint: foreign_key}
  LocationKey: int {constraint: foreign_key}
  InfrastructureKey: int {constraint: foreign_key}
  ConditionKey: int {constraint: foreign_key}
  Total_Vehicles: int
  Total_Casualties: int
}

Fact_Vehicle_Involvement: {
  shape: sql_table
  Collision_ID: string {constraint: foreign_key}
  VehicleKey: int {constraint: foreign_key}
  MotionKey: int {constraint: foreign_key}
  DynamicsKey: int {constraint: foreign_key}
}

Fact_Casualty_Involvement: {
  shape: sql_table
  Collision_ID: string {constraint: foreign_key}
  CasualtyKey: int {constraint: foreign_key}
  VehicleKey: int {constraint: foreign_key}
}

Dim_Casualty: {
  shape: sql_table
  CasualtyKey: int {constraint: primary_key}
}

Dim_Vehicle: {
  shape: sql_table
  VehicleKey: int {constraint: primary_key}
}

# Empty Dimension Tables (Inferred from relationships)
Dim_Date: {shape: sql_table}
Dim_Time: {shape: sql_table}
Dim_Location: {shape: sql_table}
Dim_Infrastructure: {shape: sql_table}
Dim_Condition: {shape: sql_table}
Dim_Pre_Collision_Motion: {shape: sql_table}
Dim_Collision_Dynamics: {shape: sql_table}

# Dimensions to Fact_Collision (Level 1 Grain)
Dim_Date -> Fact_Collision.DateKey
Dim_Time -> Fact_Collision.TimeKey
Dim_Location -> Fact_Collision.LocationKey
Dim_Infrastructure -> Fact_Collision.InfrastructureKey
Dim_Condition -> Fact_Collision.ConditionKey

# Dimensions to Fact_Vehicle_Involvement (Level 2 Grain)
Dim_Vehicle.VehicleKey -> Fact_Vehicle_Involvement.VehicleKey
Dim_Pre_Collision_Motion -> Fact_Vehicle_Involvement.MotionKey
Dim_Collision_Dynamics -> Fact_Vehicle_Involvement.DynamicsKey

# Dimensions to Fact_Casualty_Involvement (Level 2 Grain)
Dim_Casualty.CasualtyKey -> Fact_Casualty_Involvement.CasualtyKey
Dim_Vehicle.VehicleKey -> Fact_Casualty_Involvement.VehicleKey: "or -1 for Pedestrians"

# Fact to Fact Relationships (Degenerate Dimension Link)
Fact_Collision.Collision_ID -> Fact_Vehicle_Involvement.Collision_ID: "1 to 0..N"
Fact_Collision.Collision_ID -> Fact_Casualty_Involvement.Collision_ID: "1 to 0..N"
